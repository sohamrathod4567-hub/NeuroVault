# Server Port
PORT=3000

# JSON Web Token Secret (Change this in production)
JWT_SECRET=super_secret_production_key_here

# Node Environment (development | production)
NODE_ENV=production

# AI Provider Keys
# Add any of the following if you want to use external cloud providers:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# OPEN_ROUTER_API_KEY=sk-or-v1-...
